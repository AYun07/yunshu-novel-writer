{
  "name": "yunshu",
  "version": "2.6.0",
  "description": "云书 - AI智能小说创作平台",
  "author": "云书团队",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": ".",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "build:electron:win": "vite build && electron-builder --win",
    "build:electron:mac": "vite build && electron-builder --mac",
    "build:electron:linux": "vite build && electron-builder --linux",
    "preview": "vite preview",
    "electron": "wait-on http://localhost:7520 && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron\"",
    "electron:pack": "electron-builder --dir",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "build:app": "vite build",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android",
    "cap:ios": "npm run build && npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:android:apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "build:android:aab": "npm run build && npx cap sync android && cd android && ./gradlew bundleRelease",
    "build:android:release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.4",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@element-plus/icons-vue": "^2.3.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^10.7.2",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.6.5",
    "capacitor-plugin-safe-area": "^3.0.0",
    "dayjs": "^1.11.10",
    "dexie": "^4.4.2",
    "diff-match-patch": "^1.0.5",
    "docx": "^9.6.1",
    "echarts": "^5.4.3",
    "element-plus": "^2.5.1",
    "epub-gen-memory": "^1.1.2",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "lz-string": "^1.5.0",
    "mammoth": "^1.6.0",
    "marked": "^11.1.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@rushstack/eslint-patch": "^1.6.1",
    "@tsconfig/node18": "^18.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.5",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "prettier": "^3.2.4",
    "sass": "^1.70.0",
    "terser": "^5.47.1",
    "typescript": "~5.3.3",
    "unplugin-auto-import": "^0.17.3",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.0.12",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.2.1",
    "vue-tsc": "^1.8.27",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.yunshu.app",
    "productName": "云书",
    "copyright": "Copyright © 2026 云书团队",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-updater/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "云书"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build",
      "category": "Office",
      "maintainer": "云书团队",
      "vendor": "云书团队",
      "synopsis": "AI智能小说创作平台",
      "description": "一款专为小说创作者设计的智能写作工具，集成AI辅助创作、角色管理、世界观构建等功能。"
    },
    "publish": {
      "provider": "generic",
      "url": "https://yunshu.app/updates",
      "channel": "latest"
    },
    "releaseInfo": {
      "releaseNotes": "版本更新说明"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11",
    "Firefox ESR",
    "iOS >= 15",
    "Android >= 10",
    "Samsung >= 12",
    "Edge >= 90",
    "UCAndroid >= 13"
  ],
  "keywords": [
    "小说",
    "写作",
    "AI",
    "创作",
    "写作工具",
    "novel",
    "writing",
    "electron",
    "vue3",
    "pwa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yunshu/yunshu.git"
  },
  "bugs": {
    "url": "https://github.com/yunshu/yunshu/issues"
  }
}
