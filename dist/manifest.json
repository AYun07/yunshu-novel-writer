    },
    {
      "platform": "windows",
      "url": "https://www.microsoft.com/store/apps/9NBLGGH4N4R9"
    }
  ],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "document",
          "accept": ["text/plain", "text/markdown", "application/epub+zip", ".txt", ".md", ".epub"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "text/plain": [".txt"],
        "text/markdown": [".md"],
        "application/epub+zip": [".epub"],
        "application/json": [".yunshu", ".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+yunshu",
      "url": "/protocol-handler?type=%s"
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "theme_color_overrides": {
    "default": "#409eff",
    "dark": "#1a1a2e",
    "warm": "#f5a623",
    "green": "#67c23a",
    "purple": "#9b59b6"
  },
