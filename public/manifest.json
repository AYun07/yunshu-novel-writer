  "shortcuts": [
    {
      "name": "大师创作",
      "short_name": "大师创作",
      "description": "使用AI大师模式进行智能创作",
      "url": "/master-creation",
      "icons": [
        {
          "src": "/icons/shortcut-master.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "专注模式",
      "short_name": "专注模式",
      "description": "进入无干扰的专注写作模式",
      "url": "/focus-mode",
      "icons": [
        {
          "src": "/icons/shortcut-focus.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "导出中心",
      "short_name": "导出中心",
      "description": "导出小说为多种格式",
      "url": "/export-center",
      "icons": [
        {
          "src": "/icons/shortcut-export.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "新建小说",
      "short_name": "新建",
      "description": "创建一部新的小说作品",
      "url": "/novel-management?action=create",
      "icons": [
        {
          "src": "/icons/shortcut-new.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["text/plain", "text/markdown", "application/epub+zip", ".txt", ".md", ".epub"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "text/plain": [".txt"],
        "text/markdown": [".md"],
        "application/epub+zip": [".epub"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+yunshu",
      "url": "/protocol-handler?type=%s"
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "theme_color_overrides": {
    "default": "#409eff",
    "dark": "#1a1a2e",
    "warm": "#f5a623",
    "green": "#67c23a",
    "purple": "#9b59b6"
  },
  "info": {
    "developer": {
      "name": "云书团队",
      "url": "https://yunshu.app"
    },
    "version": "2.0.0",
    "release_date": "2024-01-01",
    "changelog_url": "https://yunshu.app/changelog"
  }
}
